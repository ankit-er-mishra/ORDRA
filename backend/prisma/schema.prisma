generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id                String   @id @default(cuid())
  orderId           String   @unique @map("order_id")
  platform          String   @default("Ordra Demo")
  productName       String   @map("product_name")
  productImage      String?  @map("product_image")
  sellerName        String   @map("seller_name")
  sellerId          String?  @map("seller_id")
  amount            Float
  currency          String   @default("INR")
  paymentMethod     String   @map("payment_method")
  customerEmail     String   @map("customer_email")
  customerName      String   @map("customer_name")
  estimatedDelivery DateTime @map("estimated_delivery")
  confidenceScore   Int      @default(85) @map("confidence_score")
  emotionalState    String   @default("NORMAL") @map("emotional_state")
  currentStage      String   @default("payment_verified") @map("current_stage")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  events        OrderEvent[]
  ledgerEntries LedgerEntry[]

  @@map("orders")
}

model OrderEvent {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  stage      String
  status     String   @default("PENDING")
  timestamp  DateTime @default(now())
  verifiedBy String?  @map("verified_by")
  proofData  Json?    @map("proof_data")
  notes      String?
  sortOrder  Int      @default(0) @map("sort_order")

  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@map("order_events")
}

model LedgerEntry {
  id               String   @id @default(cuid())
  orderId          String   @map("order_id")
  eventType        String   @map("event_type")
  description      String
  timestamp        DateTime @default(now())
  verifiedBy       String   @map("verified_by")
  verificationHash String   @map("verification_hash")

  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@map("ledger_entries")
}

model SellerProfile {
  id               String  @id @default(cuid())
  sellerId         String  @unique @map("seller_id")
  name             String
  location         String?
  reliabilityScore Float   @default(4.5) @map("reliability_score")
  totalOrders      Int     @default(0) @map("total_orders")
  verified         Boolean @default(false)

  @@map("seller_profiles")
}
